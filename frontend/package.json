{
  "name": "qna-ai-ui",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/qna-ai",
    "dev:ai-builder": "npm run dev --workspace=apps/ai-builder",
    "dev:base-ui": "npm run dev --workspace=apps/base-ui",
    "build": "npm run build --workspace=apps/qna-ai",
    "build:all": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}