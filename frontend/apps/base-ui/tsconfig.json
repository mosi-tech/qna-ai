{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "types": [
      "react",
      "react-dom",
      "node"
    ],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/components/*": [
        "src/tremor/components/*"
      ],
      "@/lib/*": [
        "tremor/lib/*",
        "lib/*"
      ],
      "react": ["../../node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["../../node_modules/react/jsx-runtime.js"]
    }
  },
  "include": [
    "src",
    "src/blocks/BLOCK_METADATA.json"
  ]
}