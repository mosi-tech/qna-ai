  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && tailwindcss -i ./src/global.css -o ./dist/base-ui.css",
    "build:types": "tsc --declaration --emitDeclarationOnly --noEmitOnError false",
