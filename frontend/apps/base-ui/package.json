{
  "name": "@ui-gen/base-ui",
  "version": "0.1.0",
  "description": "Base UI Block-level Components - Financial semantic blocks built on base primitives",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
